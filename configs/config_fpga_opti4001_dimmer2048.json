{
  "_comment_calibration": "brightness_to_nits.sweep_table is a REFERENCE table swept on one specific FPGA dimmer2048 + display unit; per-unit variation 5-15% is normal. For accurate nits readout on your panel, run tools/als-dimmer-sweep.py and replace calibrations/dimmer_2048.csv. Path is resolved relative to this config file's directory.",

  "sensor": {
    "type": "fpga_opti4001",
    "device": "/dev/i2c-1",
    "address": "0x1D",
    "scale_factor": 1.64
  },

  "output": {
    "type": "dimmer2048",
    "device": "/dev/i2c-1",
    "address": "0x1D"
  },

  "control": {
    "tcp_socket": {
      "enabled": true,
      "listen_address": "127.0.0.1",
      "listen_port": 9000
    },
    "unix_socket": {
      "enabled": true,
      "path": "/tmp/als-dimmer.sock",
      "permissions": "0666",
      "owner": "root",
      "group": "root"
    },
    "update_interval_ms": 500,
    "sensor_error_timeout_sec": 300,
    "fallback_brightness": 50,
    "state_file": "/home/pi/als-dimmer/state.json",
    "auto_resume_timeout_sec": 60,
    "log_level": "info",
    "minimal_i2c": true
  },

  "zones": [
    {
      "name": "night",
      "lux_range": [0, 10],
      "brightness_range": [15, 30],
      "curve": "logarithmic",
      "step_sizes": {"large": 5, "medium": 2, "small": 1},
      "error_thresholds": {"large": 20, "small": 5}
    },
    {
      "name": "indoor",
      "lux_range": [10, 500],
      "brightness_range": [30, 70],
      "curve": "linear",
      "step_sizes": {"large": 8, "medium": 3, "small": 1},
      "error_thresholds": {"large": 25, "small": 8}
    },
    {
      "name": "outdoor",
      "lux_range": [500, 100000],
      "brightness_range": [70, 100],
      "curve": "logarithmic",
      "step_sizes": {"large": 10, "medium": 4, "small": 2},
      "error_thresholds": {"large": 30, "small": 10}
    }
  ],

  "notification": {
    "enabled": true,
    "on_change_script": "/home/pi/streamdeck-ctrl/screens/display-control/scripts/als-dimmer-notify.sh"
  },

  "calibration": {
    "enabled": false,
    "sample_duration_sec": 60,
    "auto_adjust_zones": true
  },

  "brightness_to_nits": {
    "enabled": true,
    "sweep_table": "calibrations/dimmer_2048.csv"
  }
}
